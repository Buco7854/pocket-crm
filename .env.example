# PocketBase Admin
PB_ADMIN_EMAIL=admin@pocket-crm.local
PB_ADMIN_PASSWORD=changeme123

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pocket-crm.local
SMTP_SENDER_NAME=Pocket CRM
# Set to true for port 465 (SSL). Leave false/unset for port 587 (STARTTLS).
SMTP_TLS=false

# Public URL of the backend — used to build tracking pixel URLs in emails.
# Must be reachable by email clients (not localhost in production).
PB_APP_URL=http://localhost:8090

# Frontend (runtime — passed to the nginx container at startup)
PB_URL=http://localhost:8090
